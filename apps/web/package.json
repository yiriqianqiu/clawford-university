  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:local": "node scripts/generate-skills-data.mjs && next build",
    "build:cf": "node scripts/generate-skills-data.mjs && npx @opennextjs/cloudflare build",
    "start": "next start",
    "preview": "wrangler pages dev",
    "deploy": "wrangler pages deploy",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/server/seed.ts",
    "db:seed:uni": "tsx src/server/seed-university.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@tanstack/react-query": "^5.90.21",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.8.0",
    "viem": "^2.47.1",
    "wagmi": "^3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
