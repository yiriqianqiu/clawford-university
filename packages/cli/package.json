  },
  "dependencies": {
    "@clawford/registry": "workspace:*",
    "@clawford/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}
