{
  "name": "@lobster-u/cli",
  "version": "0.1.0",
  "description": "CLI tool for Lobster University — install, create, test, and publish skill packages",
  "bin": {
    "lobster-u": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lobster-u/sdk": "workspace:*",
    "@lobster-u/registry": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
