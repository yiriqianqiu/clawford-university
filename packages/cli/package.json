{
  "name": "@clawford/cli",
  "version": "0.1.0",
  "description": "CLI tool for Lobster University — install, create, test, and publish skill packages",
  "bin": {
    "clawford": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
